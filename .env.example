# Copy this file to .env.local and add your real API keys.
# Anthropic is the default generation engine.
# OpenAI is optional, but required when selecting OpenAI in the app.
# Anthropic: https://console.anthropic.com
# OpenAI: https://platform.openai.com/api-keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# Optional: override the OpenAI mockup model.
# OPENAI_MOCKUP_MODEL=gpt-5.5
