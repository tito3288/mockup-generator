# Copy this file to .env.local and add your real API keys.
# OpenAI is the default generation engine.
# Firecrawl is optional but recommended for better website research.
# Anthropic: https://console.anthropic.com
# OpenAI: https://platform.openai.com/api-keys
# Firecrawl: https://www.firecrawl.dev
ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENAI_API_KEY=your-openai-api-key-here
FIRECRAWL_API_KEY=your-firecrawl-api-key-here

# Optional model and reasoning overrides.
# OPENAI_MOCKUP_MODEL=gpt-5.5
# ANTHROPIC_MOCKUP_MODEL=claude-opus-4-7
# ANTHROPIC_EXPORT_MODEL=claude-opus-4-7
# OPENAI_REASONING_EFFORT=medium
